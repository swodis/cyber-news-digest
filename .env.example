# Optional runtime diagnostics toggle
# Set to 1 to print verbose logs to stderr.
# DIGEST_VERBOSE=1

# SSL options:
# Set to 1 (default) to require TLS verification.
# DIGEST_SSL_VERIFY=1
# Retry with TLS verification disabled on failure.
# If unset, this auto-enables when HTTP(S)_PROXY is detected.
# Set to 0 to keep strict TLS and fail on SSL errors.
# DIGEST_SSL_FALLBACK=1
# Optional: custom CA bundle path if your corporate CA is required.
# Will also use SSL_CERT_FILE and REQUESTS_CA_BUNDLE if set.
# DIGEST_CA_BUNDLE=
